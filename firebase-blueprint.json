{
  "entities": {
    "Company": {
      "title": "Company",
      "description": "Firma bilgilerini saklayan ana varlık.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "vkn": { "type": "string" },
        "taxOffice": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "ownerId": { "type": "string", "description": "Firmayı oluşturan mali müşavirin UID'si" }
      },
      "required": ["title", "ownerId"]
    },
    "Personnel": {
      "title": "Personnel",
      "description": "Firmaya bağlı çalışan personel bilgileri.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "fullName": { "type": "string" },
        "idNumber": { "type": "string" },
        "role": { "type": "string" },
        "netSalary": { "type": "number" },
        "startDate": { "type": "string", "format": "date" },
        "leaveStatus": { "type": "string", "enum": ["Aktif", "İzinli", "Ayrıldı"] },
        "type": { "type": "string", "enum": ["normal", "huzur_hakki"] }
      },
      "required": ["companyId", "fullName", "type"]
    },
    "Message": {
      "title": "Message",
      "description": "Müşteri iletişim mesajları.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "sender": { "type": "string" },
        "text": { "type": "string" },
        "time": { "type": "string" },
        "type": { "type": "string", "enum": ["sent", "received"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "text", "type"]
    },
    "User": {
      "title": "User",
      "description": "Kullanıcı profil bilgileri.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "username": { "type": "string" },
        "title": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["fullName", "email"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Kullanıcı ayarları.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "order": { "type": "array", "items": { "type": "string" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Task": {
      "title": "Task",
      "description": "Kullanıcı görevleri.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["text", "completed"]
    },
    "BeyannameTracking": {
      "title": "BeyannameTracking",
      "description": "Beyanname takip bilgileri.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "period": { "type": "string" },
        "statuses": { "type": "object" },
        "notes": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["companyId", "period", "ownerId"]
    },
    "CariTransaction": {
      "title": "CariTransaction",
      "description": "Cari hesap ve tahsilat işlemleri.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "companyId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["Tahsilat", "Fatura"] },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "desc": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "companyId", "amount", "type", "date"]
    },
    "VergiTakip": {
      "title": "VergiTakip",
      "description": "5/10 Tevkifatlı firmalar için KDV ve vergi takip verileri.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firma_id": { "type": "string" },
        "ay": { "type": "integer" },
        "yil": { "type": "integer" },
        "kdv2Borc": { "type": "number" },
        "kdv1Borc": { "type": "number" },
        "stopajBorc": { "type": "number" },
        "sgkBorc": { "type": "number" },
        "kvGvBorc": { "type": "number" },
        "digerBorc": { "type": "number" },
        "kdvIadesi": { "type": "number" },
        "ithaldKdv": { "type": "number" },
        "hesaplananKdv": { "type": "number" },
        "indirilecekKdv": { "type": "number" },
        "satisFaturaMatrahi": { "type": "number" },
        "alisTeVkifatliMatrahi": { "type": "number" },
        "alisTevsizMatrahi": { "type": "number" },
        "devredenBorc": { "type": "number" },
        "devredenKdv": { "type": "number" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["firma_id", "ay", "yil"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Kullanıcı profilleri"
    },
    "/users/{userId}/settings/{settingId}": {
      "schema": "Settings",
      "description": "Kullanıcı ayarları"
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Kullanıcı görevleri"
    },
    "/cari_transactions/{transactionId}": {
      "schema": "CariTransaction",
      "description": "Cari hesap ve tahsilat kayıtları"
    },
    "/vergi_takip/{recordId}": {
      "schema": "VergiTakip",
      "description": "KDV ve vergi takip kayıtları"
    },
    "/beyanname_tracking/{trackingId}": {
      "schema": "BeyannameTracking",
      "description": "Beyanname takip kayıtları"
    },
    "/companies/{companyId}": {
      "schema": "Company",
      "description": "Firmaların listesi"
    },
    "/companies/{companyId}/personnel/{personnelId}": {
      "schema": "Personnel",
      "description": "Firmaya ait personel listesi"
    },
    "/companies/{companyId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Firmaya ait mesaj geçmişi"
    }
  }
}
